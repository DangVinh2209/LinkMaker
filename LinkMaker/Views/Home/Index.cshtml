@{
    ViewData["Title"] = "Home Page";
}

<section class="hero-section">
    <div class="container">
        <div class="hero-box">
            <h1 class="hero-title">
                Welcome to <span>LinkMaker</span>
            </h1>
            <div class="hero-actions">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a asp-controller="Url" asp-action="Create" class="btn hero-btn hero-btn-primary">
                        Create Short Link
                    </a>
                    <a asp-controller="Url" asp-action="Index" class="btn hero-btn hero-btn-outline">
                        View Links
                    </a>
                }
            </div>
        </div>
    </div>
</section>