@using Microsoft.AspNetCore.Identity
@using LinkMaker.Data.Entities.Identity
@inject SignInManager<LinkMakerUser> SignInManager
@inject UserManager<LinkMakerUser> UserManager

<div class="d-flex align-items-center gap-2">
    @if (SignInManager.IsSignedIn(User))
    {
        var currentUser = await UserManager.GetUserAsync(User);
        var displayName = currentUser?.FullName ?? UserManager.GetUserName(User);

        <a id="manage" class="nav-link" asp-area="Identity" asp-page="/Account/Manage/Profile" title="My Profile">
            @displayName
        </a>
        @* <a id="manage" class="nav-link" asp-controller="UserProfile" asp-action="Details" title="My Profile">
            @displayName
        </a> *@

        <form id="logoutForm" class="d-inline" asp-area="Identity" asp-page="/Account/Logout"
              asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
            <button id="logout" type="submit" class="btn hero-btn hero-btn-outline py-2 px-3">
                Logout
            </button>
        </form>
    }
    else
    {
        <a class="btn hero-btn hero-btn-outline py-2 px-3" id="register" asp-area="Identity" asp-page="/Account/Register">
            Register
        </a>
        <a class="btn hero-btn hero-btn-primary py-2 px-3" id="login" asp-area="Identity" asp-page="/Account/Login">
            Login
        </a>
    }
</div>
@* mới thêm cái identity = profile  *@