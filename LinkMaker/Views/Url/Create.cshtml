<h1>Create</h1>

<h4>Link</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <!-- Long URL -->
            <div class="form-group">
                <label asp-for="YourLink" class="control-label"></label>
                <input asp-for="YourLink" class="form-control" id="longUrl" />
                <span asp-validation-for="YourLink" class="text-danger"></span>
            </div>

            <!-- Generate button -->
            <div class="form-group mt-2 mb-2">
                <button type="button" class="btn btn-secondary" onclick="generateShortLink()">
                    Generate
                </button>
            </div>

            <!-- Short URL -->
            <div class="form-group">
                <label asp-for="NewLink" class="control-label"></label>
                <input asp-for="NewLink" class="form-control" id="shortUrl" />
                <span asp-validation-for="NewLink" class="text-danger"></span>
            </div>

            <div id="qrPreview" class="mt-3" style="display:none;">
                <p>QR Preview:</p>
                <img id="qrImage" src="" style="width:150px;" />
            </div>

            <!-- Submit -->
            <div class="form-group mt-3">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    <script>
        function generateShortLink() {
            const longUrl = document.getElementById("longUrl").value;

            if (!longUrl) {
                alert("Please enter a URL first");
                return;
            }

             fetch('/Url/GenerateShortLink', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded'
            },
            body: `longUrl=${encodeURIComponent(longUrl)}`
            })
            .then(response => response.json())
        //     .then(data => {
        //         document.getElementById("shortUrl").value = data.shortLink;
        //         const qrImg = document.getElementById("qrImage");
        // qrImg.src = `/Qr/Generate?text=${encodeURIComponent(data.shortLink)}`;
        // document.getElementById("qrPreview").style.display = "block";
        //     })
                .then(data => {
            document.getElementById("shortUrl").value = data.shortLink;

            const qrImg = document.getElementById("qrImage");
            const qrContainer = document.getElementById("qrPreview");

            // 1. Point to QRCode controller
            // 2. Point to GetQRCode action
            // 3. Pass the short link as 'text'
            qrImg.src = "/QRCode/GetQRCode?text=" + encodeURIComponent(data.shortLink);
    
            qrContainer.style.display = "block";
        })
            .catch(error => console.error('Error:', error));
        }
    </script>
}
