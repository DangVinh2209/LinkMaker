@* @model LinkMaker.Data.Entities.Url *@
@model LinkMaker.Common.DTOS.UrlDTO


@{
    ViewData["Title"] = "Edit";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Modify your link</h1>

@* <h4>Major</h4> *@
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <div class="form-group">
                <label asp-for="YourLink" class="control-label"></label>
                <input asp-for="YourLink" class="form-control" />
                <span asp-validation-for="YourLink" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="NewLink" class="control-label"></label>
                <input asp-for="NewLink" class="form-control" />
                <span asp-validation-for="NewLink" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save your choice " class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
